# Polymarket CLOB API credentials
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Ethereum wallet
PRIVATE_KEY=
WALLET_ADDRESS=

# Trading parameters
BANKROLL=2000

# LLM estimation (both optional - falls back to statistical-only)
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
LLM_ESTIMATION_ENABLED=true
LLM_MODEL=claude-haiku-4-5-20251001
PERPLEXITY_MODEL=sonar
LLM_ESTIMATE_WEIGHT=0.35

# Railway sets PORT automatically; override locally if needed
PORT=8080
HEALTH_CHECK_ENABLED=true
